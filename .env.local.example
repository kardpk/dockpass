# BoatCheckin Environment Variables
# Copy to .env.local — NEVER commit .env.local
# See docs/agents/INFRA_SETUP.md for how to get each value

# ============================================
# SUPABASE (Step 3 in INFRA_SETUP.md)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================
# REDIS — Upstash (Step 4)
# ============================================
UPSTASH_REDIS_URL=https://[endpoint].upstash.io
UPSTASH_REDIS_TOKEN=...

# ============================================
# REDIS — Render worker (Step 6)
# ============================================
REDIS_URL=redis://...

# ============================================
# STRIPE CONNECT (Step 7)
# ============================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# ── Stripe Price IDs (create in Stripe Dashboard) ──
STRIPE_PRICE_SOLO_MONTHLY=price_...
STRIPE_PRICE_SOLO_ANNUAL=price_...
STRIPE_PRICE_CAPTAIN_MONTHLY=price_...
STRIPE_PRICE_CAPTAIN_ANNUAL=price_...
STRIPE_PRICE_FLEET_MONTHLY=price_...
STRIPE_PRICE_FLEET_ANNUAL=price_...
STRIPE_PRICE_MARINA_MONTHLY=price_...
STRIPE_PRICE_MARINA_ANNUAL=price_...

# ============================================
# EMAIL — Resend (Step 8)
# ============================================
RESEND_API_KEY=re_...

# ============================================
# SMS — Twilio (Step 9)
# ============================================
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# ============================================
# MAPS — Mapbox (Step 10)
# ============================================
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# ============================================
# BOT PROTECTION — Cloudflare Turnstile (Step 11)
# ============================================
NEXT_PUBLIC_TURNSTILE_SITE_KEY=...
TURNSTILE_SECRET_KEY=...

# ============================================
# PUSH NOTIFICATIONS — VAPID (Step 12)
# Generate: npx web-push generate-vapid-keys
# ============================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...

# ============================================
# REVENUE APIs (Step 13)
# ============================================
BUOY_API_KEY=
BUOY_API_URL=https://api.buoy.insure
TINT_API_KEY=
TINT_API_URL=
BOATUS_AFFILIATE_URL=https://www.boatus.com/?ref=...

# ============================================
# SECURITY SECRETS (Step 12)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================
QR_HMAC_SECRET=
TRIP_LINK_SECRET=


# ============================================
# OPENPHONE (business phone — not automated)
# ============================================
OPENPHONE_API_KEY=
OPENPHONE_NUMBER=+1786...

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
